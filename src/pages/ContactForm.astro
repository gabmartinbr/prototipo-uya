---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacto | Soporte Taxirife Tenerife">
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto grid md:grid-cols-5 gap-12">
        <div class="md:col-span-2 space-y-8">
          <h1 class="text-4xl font-black text-blue-900 leading-tight">
            Estamos aquí para <span class="text-blue-600">ayudarte</span>.
          </h1>
          <p class="text-slate-600">
            ¿Tienes un objeto perdido o necesitas un transporte especial para
            grupos grandes?
          </p>

          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div
                class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-2xl"
                aria-hidden="true"
              >
                📞
              </div>
              <div>
                <p class="text-xs font-bold uppercase text-slate-400">
                  Teléfono 24h
                </p>
                <a
                  href="tel:+34922000000"
                  class="text-xl font-bold text-blue-900">+34 922 000 000</a
                >
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div
                class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center text-2xl"
                aria-hidden="true"
              >
                📍
              </div>
              <div>
                <p class="text-xs font-bold uppercase text-slate-400">
                  Oficina Aeropuerto
                </p>
                <p class="text-lg font-bold text-blue-900">
                  Terminal Llegadas, Planta 0
                </p>
              </div>
            </div>
          </div>
        </div>

        <div
          class="md:col-span-3 bg-slate-50 p-8 rounded-3xl border border-slate-200"
        >
          <form class="grid grid-cols-1 gap-4">
            <div class="grid md:grid-cols-2 gap-4">
              <div class="space-y-2">
                <label for="c-name" class="text-sm font-bold">Nombre</label>
                <input
                  type="text"
                  id="c-name"
                  class="w-full p-4 border-2 border-white rounded-xl focus:border-blue-500 outline-none shadow-sm"
                />
              </div>
              <div class="space-y-2">
                <label for="c-email" class="text-sm font-bold">Email</label>
                <input
                  type="email"
                  id="c-email"
                  class="w-full p-4 border-2 border-white rounded-xl focus:border-blue-500 outline-none shadow-sm"
                />
              </div>
            </div>
            <div class="space-y-2">
              <label for="c-msg" class="text-sm font-bold">Tu Mensaje</label>
              <textarea
                id="c-msg"
                rows="5"
                class="w-full p-4 border-2 border-white rounded-xl focus:border-blue-500 outline-none shadow-sm"
                placeholder="¿Cómo podemos ayudarte?"></textarea>
            </div>
            <button
              class="bg-blue-900 text-white py-4 rounded-xl font-bold text-lg hover:bg-blue-800 transition-colors"
              >Enviar Mensaje</button
            >
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
