---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Gestionar mi Reserva | Taxirife Tenerife">
  <section class="relative min-h-screen py-12 flex items-center justify-center bg-slate-900">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1579090814807-60808035e1cb?q=80&w=2000&auto=format&fit=crop"
        class="w-full h-full object-cover opacity-30"
        alt="Tenerife View"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/40 via-slate-900/80 to-slate-900"></div>
    </div>

    <div class="container mx-auto px-4 z-10">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <span class="bg-blue-600 text-white px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-[0.3em] mb-4 inline-block">Área de Clientes</span>
          <h1 class="text-4xl md:text-5xl font-black text-white italic">
            GESTIÓN DE <span class="text-yellow-400">RESERVAS</span>
          </h1>
        </div>

        <div class="grid lg:grid-cols-2 gap-8 items-start">
          <div class="bg-white p-8 rounded-[2.5rem] shadow-2xl border border-white/20 relative overflow-hidden">
            <h2 class="text-2xl font-black text-blue-900 mb-2 italic uppercase">Localizar Traslado</h2>
            <p class="text-slate-500 mb-8 text-sm font-medium">Introduce los datos de tu confirmación para acceder.</p>

            <form id="search-form" class="space-y-6">
              <div class="space-y-2">
                <label for="res-code" class="block text-[10px] font-black uppercase tracking-widest text-blue-600 ml-1">Localizador de Reserva</label>
                <input type="text" id="res-code" placeholder="Ej: TAXI10" required class="w-full p-5 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-blue-600 outline-none text-2xl font-mono font-bold tracking-widest uppercase transition-all" />
              </div>
              <div class="space-y-2">
                <label for="res-email" class="block text-[10px] font-black uppercase tracking-widest text-blue-600 ml-1">Email del Titular</label>
                <input type="email" id="res-email" placeholder="tu@email.com" required class="w-full p-5 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-blue-600 outline-none font-bold text-slate-700" />
              </div>
              <button type="submit" class="w-full bg-blue-700 text-white py-5 rounded-2xl font-black text-xl hover:bg-blue-800 transition-all flex items-center justify-center gap-3 group">
                <span>CONSULTAR AHORA</span>
              </button>
            </form>

            <div id="search-error" class="mt-4 p-4 bg-red-50 text-red-700 rounded-xl text-xs font-bold hidden border border-red-100 uppercase">
              ⚠️ Reserva no encontrada. Prueba con 'TAXI10'.
            </div>
          </div>

          <div class="space-y-6">
            <div class="bg-slate-900 text-white rounded-[2.5rem] shadow-2xl relative overflow-hidden border border-white/10 group">
              <div class="p-8 pb-10 border-b border-dashed border-white/20">
                <div class="flex justify-between items-center mb-8">
                  <h2 class="text-sm font-black tracking-[0.3em] text-blue-400 uppercase italic">Estado del Ticket</h2>
                  <span id="status-badge" class="px-3 py-1 bg-white/10 rounded-lg text-[10px] font-bold opacity-40 uppercase">PENDIENTE</span>
                </div>

                <div id="booking-details" class="space-y-8 opacity-20 grayscale transition-all duration-700">
                  <div class="flex justify-between items-start">
                    <div>
                      <p class="text-[10px] font-black text-slate-500 uppercase">Localizador</p>
                      <p class="text-3xl font-mono font-black tracking-tighter text-yellow-400" id="view-code">------</p>
                    </div>
                    <div class="text-right">
                      <p class="text-[10px] font-black text-slate-500 uppercase">Total a pagar</p>
                      <p class="text-4xl font-black text-white" id="view-price">--€</p>
                    </div>
                  </div>

                  <div class="grid grid-cols-2 gap-6">
                    <div class="bg-white/5 p-4 rounded-2xl">
                      <p class="text-[9px] font-black text-blue-400 uppercase mb-1">Fecha Recogida</p>
                      <input type="text" id="edit-date" class="bg-transparent font-bold text-sm outline-none w-full border-none p-0 focus:text-yellow-400" value="-- / -- / --" readonly />
                    </div>
                    <div class="bg-white/5 p-4 rounded-2xl">
                      <p class="text-[9px] font-black text-blue-400 uppercase mb-1">Hora Estimada</p>
                      <input type="text" id="edit-time" class="bg-transparent font-bold text-sm outline-none w-full border-none p-0 focus:text-yellow-400" value="--:--h" readonly />
                    </div>
                  </div>

                  <div>
                    <p class="text-[10px] font-black text-slate-500 uppercase mb-2">Destino Final</p>
                    <input type="text" id="edit-dest" class="bg-transparent font-bold text-lg outline-none w-full border-none p-0 focus:text-yellow-400" value="Selecciona una reserva..." readonly />
                  </div>

                  <div class="pt-4 flex flex-col sm:flex-row gap-4">
                    <button id="btn-modify" class="flex-grow bg-blue-600 hover:bg-blue-500 p-4 rounded-xl text-xs font-black uppercase transition-all hidden">Modificar Datos</button>
                    <button id="btn-save" class="flex-grow bg-green-600 hover:bg-green-500 p-4 rounded-xl text-xs font-black uppercase transition-all hidden italic">Guardar Cambios</button>
                    <a id="btn-cancel" href="#" class="px-6 py-4 border border-red-500/50 text-red-500 hover:bg-red-500/10 rounded-xl text-xs font-black uppercase transition-all text-center hidden">Cancelar Reserva</a>
                  </div>
                </div>
              </div>
            </div>

            <div class="bg-yellow-400/10 border-2 border-yellow-400/20 p-5 rounded-3xl flex items-start gap-4">
              <div class="text-yellow-400 pt-1">🚕</div>
              <p class="text-xs text-yellow-100 leading-relaxed font-medium">
                <strong class="text-yellow-400 uppercase block mb-1">Política de cambios:</strong>
                Puedes modificar tus datos directamente arriba. Para cancelaciones, se enviará un email automático al soporte técnico.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById("search-form");
  const details = document.getElementById("booking-details");
  const errorMsg = document.getElementById("search-error");
  const badge = document.getElementById("status-badge");
  
  // Elementos de vista/edición
  const vCode = document.getElementById("view-code");
  const vPrice = document.getElementById("view-price");
  const eDate = document.getElementById("edit-date") as HTMLInputElement;
  const eTime = document.getElementById("edit-time") as HTMLInputElement;
  const eDest = document.getElementById("edit-dest") as HTMLInputElement;

  // Botones
  const btnModify = document.getElementById("btn-modify");
  const btnSave = document.getElementById("btn-save");
  const btnCancel = document.getElementById("btn-cancel") as HTMLAnchorElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const codeInput = (document.getElementById("res-code") as HTMLInputElement).value;

    if (codeInput.toUpperCase() === "TAXI10") {
      errorMsg?.classList.add("hidden");
      details?.classList.remove("opacity-20", "grayscale");
      
      // Actualizar Estado
      if (badge) {
        badge.textContent = "CONFIRMADA";
        badge.className = "px-3 py-1 bg-green-500 text-white rounded-lg text-[10px] font-bold uppercase";
      }

      // Rellenar Datos
      if (vCode) vCode.textContent = "TX-7742";
      if (vPrice) vPrice.textContent = "25,00€";
      eDate.value = "28 MARZO 2026";
      eTime.value = "14:30H";
      eDest.value = "HOTEL GRAN TACANDE, ADEJE";

      // Mostrar Botones y configurar Mailto
      btnModify?.classList.remove("hidden");
      btnCancel?.classList.remove("hidden");
      btnCancel.href = `mailto:soporte@taxirife.com?subject=Cancelar Reserva TX-7742&body=Hola, deseo cancelar mi reserva con localizador TX-7742 a nombre de ${ (document.getElementById("res-email") as HTMLInputElement).value }.`;
      
    } else {
      errorMsg?.classList.remove("hidden");
      details?.classList.add("opacity-20", "grayscale");
    }
  });

  // Lógica de Modificación
  btnModify?.addEventListener("click", () => {
    eDate.readOnly = false;
    eTime.readOnly = false;
    eDest.readOnly = false;
    eDate.focus();
    
    btnModify.classList.add("hidden");
    btnSave?.classList.remove("hidden");
    eDate.classList.add("text-yellow-400", "animate-pulse");
  });

  btnSave?.addEventListener("click", () => {
    eDate.readOnly = true;
    eTime.readOnly = true;
    eDest.readOnly = true;
    
    eDate.classList.remove("text-yellow-400", "animate-pulse");
    btnSave.classList.add("hidden");
    btnModify?.classList.remove("hidden");
    
    alert("¡Datos actualizados correctamente en tu ticket!");
  });
</script>