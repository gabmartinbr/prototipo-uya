---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Gestionar mi Reserva | TaxiAir Tenerife">
  <section class="relative min-h-screen py-12 flex items-center justify-center bg-slate-900">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1579090814807-60808035e1cb?q=80&w=2000&auto=format&fit=crop" 
        class="w-full h-full object-cover opacity-30"
        alt="Tenerife View"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/40 via-slate-900/80 to-slate-900"></div>
    </div>

    <div class="container mx-auto px-4 z-10">
      <div class="max-w-5xl mx-auto">
        
        <div class="text-center mb-12">
            <span class="bg-blue-600 text-white px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-[0.3em] mb-4 inline-block">Área de Clientes</span>
            <h1 class="text-4xl md:text-5xl font-black text-white italic">GESTIÓN DE <span class="text-yellow-400">RESERVAS</span></h1>
        </div>

        <div class="grid lg:grid-cols-2 gap-8 items-start">
          
          <div class="bg-white p-8 rounded-[2.5rem] shadow-2xl border border-white/20 relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-10">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20" viewBox="0 0 24 24"><path fill="currentColor" d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5A6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5S14 7.01 14 9.5S11.99 14 9.5 14"/></svg>
            </div>

            <h2 class="text-2xl font-black text-blue-900 mb-2 italic uppercase">Localizar Traslado</h2>
            <p class="text-slate-500 mb-8 text-sm font-medium">Introduce los datos de tu confirmación para acceder.</p>
            
            <form id="search-form" class="space-y-6">
              <div class="space-y-2">
                <label for="res-code" class="block text-[10px] font-black uppercase tracking-widest text-blue-600 ml-1">Localizador de Reserva</label>
                <input 
                  type="text" 
                  id="res-code" 
                  placeholder="Ej: TAXI10" 
                  required
                  class="w-full p-5 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-blue-600 focus:ring-0 outline-none text-2xl font-mono font-bold tracking-widest uppercase transition-all placeholder:opacity-30"
                />
              </div>

              <div class="space-y-2">
                <label for="res-email" class="block text-[10px] font-black uppercase tracking-widest text-blue-600 ml-1">Email del Titular</label>
                <input 
                  type="email" 
                  id="res-email" 
                  placeholder="tu@email.com" 
                  required
                  class="w-full p-5 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-blue-600 focus:ring-0 outline-none font-bold transition-all text-slate-700"
                />
              </div>

              <button 
                type="submit" 
                class="w-full bg-blue-700 text-white py-5 rounded-2xl font-black text-xl hover:bg-blue-800 hover:shadow-[0_10px_20px_rgba(29,78,216,0.3)] transition-all flex items-center justify-center gap-3 group"
              >
                <span>CONSULTAR AHORA</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </button>
            </form>

            <div id="search-error" role="alert" class="mt-4 p-4 bg-red-50 text-red-700 rounded-xl text-xs font-bold hidden border border-red-100 uppercase tracking-tighter">
                ⚠️ Error: No se encuentra la reserva. Revisa el código 'TAXI10' para el demo.
            </div>
          </div>

          <div class="space-y-6">
            <div class="bg-slate-900 text-white rounded-[2.5rem] shadow-2xl relative overflow-hidden border border-white/10 group">
              <div class="absolute -left-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-slate-900 rounded-full border-r border-white/10 z-20"></div>
              <div class="absolute -right-4 top-1/2 -translate-y-1/2 w-8 h-8 bg-slate-900 rounded-full border-l border-white/10 z-20"></div>

              <div class="p-8 pb-10 border-b border-dashed border-white/20">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-sm font-black tracking-[0.3em] text-blue-400 uppercase italic">Estado del Ticket</h2>
                    <span id="status-badge" class="px-3 py-1 bg-white/10 rounded-lg text-[10px] font-bold opacity-40">PENDIENTE</span>
                </div>
                
                <div id="booking-details" class="space-y-8 opacity-20 grayscale transition-all duration-700">
                  <div class="flex justify-between items-start">
                    <div>
                      <p class="text-[10px] font-black text-slate-500 uppercase">Localizador</p>
                      <p class="text-3xl font-mono font-black tracking-tighter text-yellow-400" id="view-code">------</p>
                    </div>
                    <div class="text-right">
                      <p class="text-[10px] font-black text-slate-500 uppercase">Total a pagar</p>
                      <p class="text-4xl font-black text-white" id="view-price">--€</p>
                    </div>
                  </div>

                  <div class="grid grid-cols-2 gap-6">
                    <div class="bg-white/5 p-4 rounded-2xl">
                      <p class="text-[9px] font-black text-blue-400 uppercase mb-1">Fecha de Recogida</p>
                      <p class="font-bold text-sm" id="view-date">-- / -- / --</p>
                    </div>
                    <div class="bg-white/5 p-4 rounded-2xl">
                      <p class="text-[9px] font-black text-blue-400 uppercase mb-1">Hora Estimada</p>
                      <p class="font-bold text-sm" id="view-time">--:--h</p>
                    </div>
                  </div>

                  <div>
                    <p class="text-[10px] font-black text-slate-500 uppercase mb-2">Destino Final</p>
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 bg-yellow-400 rounded-full shadow-[0_0_10px_#fbbf24]"></div>
                        <p class="font-bold text-lg leading-tight" id="view-dest">Selecciona una reserva activa...</p>
                    </div>
                  </div>

                  <div class="pt-4 flex gap-4">
                    <button class="flex-grow bg-blue-600 hover:bg-blue-500 p-4 rounded-xl text-xs font-black uppercase transition-all">Modificar Datos</button>
                    <button class="px-6 py-4 border border-red-500/50 text-red-500 hover:bg-red-500/10 rounded-xl text-xs font-black uppercase transition-all">Cancelar</button>
                  </div>
                </div>
              </div>
              
              <div class="p-6 bg-white/5 flex items-center justify-between gap-4">
                  <div class="flex items-center gap-2">
                      <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                      <span class="text-[10px] font-bold text-slate-400">Soporte 24/7 disponible</span>
                  </div>
                  <img src="https://api.iconify.design/logos:visa.svg?color=white" class="h-3 opacity-30 grayscale" alt="Visa" />
              </div>
            </div>

            <div class="bg-yellow-400/10 border-2 border-yellow-400/20 p-5 rounded-3xl flex items-start gap-4">
              <div class="text-yellow-400 pt-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <p class="text-xs text-yellow-100 leading-relaxed font-medium">
                <strong class="text-yellow-400 uppercase block mb-1">Política de cambios:</strong> 
                Las modificaciones son gratuitas hasta <strong>24h antes</strong> del servicio. Para urgencias, contacte por WhatsApp.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('search-form');
  const details = document.getElementById('booking-details');
  const errorMsg = document.getElementById('search-error');
  const badge = document.getElementById('status-badge');

  const vCode = document.getElementById('view-code');
  const vPrice = document.getElementById('view-price');
  const vDate = document.getElementById('view-date');
  const vTime = document.getElementById('view-time');
  const vDest = document.getElementById('view-dest');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const codeInput = (document.getElementById('res-code') as HTMLInputElement).value;
    
    if(codeInput.toUpperCase() === 'TAXI10') {
      errorMsg?.classList.add('hidden');
      details?.classList.remove('opacity-20', 'grayscale');
      if(badge) {
          badge.textContent = 'CONFIRMADA';
          badge.classList.remove('bg-white/10', 'opacity-40');
          badge.classList.add('bg-green-500', 'text-white');
      }
      
      if(vCode) vCode.textContent = 'TX-7742';
      if(vPrice) vPrice.textContent = '25,00€';
      if(vDate) vDate.textContent = '28 MARZO 2026';
      if(vTime) vTime.textContent = '14:30H';
      if(vDest) vDest.textContent = 'HOTEL GRAN TACANDE, ADEJE';
    } else {
      errorMsg?.classList.remove('hidden');
      details?.classList.add('opacity-20', 'grayscale');
      if(badge) {
          badge.textContent = 'NO ENCONTRADA';
          badge.classList.add('bg-red-500', 'text-white');
      }
    }
  });
</script>