---
import Layout from "../layouts/Layout.astro";

const DESTINOS_SUR = [
  { id: "adeje", name: "Costa Adeje / Fañabé", price: 30 },
  { id: "cristianos", name: "Los Cristianos", price: 25 },
  { id: "americas", name: "Playa de las Américas", price: 28 },
  { id: "gigantes", name: "Los Gigantes / Pto. Santiago", price: 65 },
  { id: "golf", name: "Golf del Sur / Amarilla Golf", price: 20 },
  { id: "medano", name: "El Médano", price: 15 },
  { id: "callao", name: "Callao Salvaje / Playa Paraíso", price: 35 },
  { id: "alcala", name: "Alcalá", price: 45 },
  { id: "puerto", name: "Puerto de la Cruz", price: 110 },
  { id: "santacruz", name: "Santa Cruz de Tenerife", price: 85 },
];

const DESTINOS_NORTE = [
  { id: "santacruz", name: "Santa Cruz Centro", price: 20 },
  { id: "lalaguna", name: "La Laguna", price: 15 },
  { id: "puerto", name: "Puerto de la Cruz", price: 35 },
  { id: "orotava", name: "La Orotava", price: 40 },
  { id: "garachico", name: "Garachico", price: 75 },
  { id: "buenavista", name: "Buenavista del Norte", price: 95 },
  { id: "adeje_n", name: "Costa Adeje (Sur)", price: 105 },
  { id: "cristianos_n", name: "Los Cristianos (Sur)", price: 110 },
];

// Definición de las 5 categorías de vehículos de tu catálogo
const VEHICULOS = [
  { id: "standard", name: "Standard Confort", icon: "🚗", extra: 0, desc: "Económico" },
  { id: "eco", name: "Eco Premium", icon: "⚡", extra: 10, desc: "100% Eléctrico" },
  { id: "premium", name: "Premium Confort", icon: "✨", extra: 25, desc: "Alta Gama" },
  { id: "van", name: "Van de Grupo", icon: "🚐", extra: 20, desc: "Hasta 8 PAX" },
  { id: "city", name: "Ciudad", icon: "🏙️", extra: -5, desc: "Trayecto corto" },
];
---

<Layout title="Reservar Traslado Oficial | TaxiAir">
  <section class="relative min-h-screen py-12 flex items-center justify-center bg-slate-900">
    <div class="absolute inset-0 z-0">
      <img
        src="https://plus.unsplash.com/premium_photo-1700566982560-31ed8b46991a?q=80&w=2000&auto=format&fit=crop"
        class="w-full h-full object-cover opacity-40"
        alt="Tenerife"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/50 via-slate-900/80 to-slate-900"></div>
    </div>

    <div class="container mx-auto px-4 z-10">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-center">
        
        <div class="lg:col-span-4 text-white space-y-8">
          <div>
            <span class="bg-yellow-400 text-blue-900 px-4 py-1 rounded-full text-xs font-black uppercase tracking-widest inline-block mb-4">
              Taxi Oficial Tenerife
            </span>
            <h1 class="text-5xl font-black leading-tight italic uppercase">
              RESERVA TU <span class="text-yellow-400">VEHÍCULO</span>
            </h1>
            <p class="text-lg text-slate-300 mt-6 leading-relaxed">
              Selecciona tu destino y el tipo de coche que mejor se adapte a tus necesidades.
            </p>
          </div>
        </div>

        <div class="lg:col-span-8">
          <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-white/20">
            <div class="bg-blue-700 p-6 text-white text-center">
              <h2 class="text-2xl font-black italic uppercase tracking-tighter">Configura tu Traslado</h2>
            </div>

            <form id="booking-form" class="p-8 space-y-8">
              
              <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label class="text-[11px] font-black text-blue-600 uppercase tracking-widest">1. Aeropuerto Origen</label>
                  <div class="flex gap-2">
                    <label class="flex-1 cursor-pointer">
                      <input type="radio" name="airport" value="sur" checked class="sr-only peer" />
                      <div class="py-3 border-2 border-slate-100 rounded-xl bg-slate-50 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition-all text-center font-black text-slate-500 peer-checked:text-blue-700 uppercase text-xs">Sur (TFS)</div>
                    </label>
                    <label class="flex-1 cursor-pointer">
                      <input type="radio" name="airport" value="norte" class="sr-only peer" />
                      <div class="py-3 border-2 border-slate-100 rounded-xl bg-slate-50 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition-all text-center font-black text-slate-500 peer-checked:text-blue-700 uppercase text-xs">Norte (TFN)</div>
                    </label>
                  </div>
                </div>

                <div class="space-y-2">
                  <label for="travel-date" class="text-[11px] font-black text-blue-600 uppercase tracking-widest">2. Fecha</label>
                  <input type="date" id="travel-date" required class="w-full p-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:border-blue-600 outline-none font-bold text-slate-700" />
                </div>
              </div>

              <div class="space-y-2">
                <label for="dest-select" class="text-[11px] font-black text-blue-600 uppercase tracking-widest">3. Destino</label>
                <select id="dest-select" required class="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-blue-600 outline-none font-bold text-slate-800 cursor-pointer"></select>
              </div>

              <div class="space-y-3">
                <label class="text-[11px] font-black text-blue-600 uppercase tracking-widest">4. Tipo de Vehículo</label>
                <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
                  {VEHICULOS.map((v) => (
                    <label class="cursor-pointer">
                      <input type="radio" name="vehicle" value={v.id} data-extra={v.extra} checked={v.id === 'standard'} class="sr-only peer" />
                      <div class="h-full p-3 border-2 border-slate-100 rounded-xl bg-slate-50 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition-all text-center flex flex-col items-center justify-center">
                        <span class="text-2xl mb-1">{v.icon}</span>
                        <p class="font-black text-[9px] uppercase leading-tight">{v.name}</p>
                        <p class="text-[8px] text-slate-400 font-bold mt-1 uppercase">{v.desc}</p>
                      </div>
                    </label>
                  ))}
                </div>
              </div>

              <div class="bg-slate-900 rounded-[2rem] p-6 text-white shadow-2xl">
                <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                  <div class="text-center md:text-left">
                    <p class="text-blue-400 text-[10px] font-black uppercase tracking-widest">Precio estimado cerrado</p>
                    <div class="flex items-baseline justify-center md:justify-start gap-1">
                      <span id="final-price" class="text-5xl font-black text-yellow-400">0,00</span>
                      <span class="text-xl font-bold text-yellow-400">€</span>
                    </div>
                  </div>
                  <button type="submit" class="w-full md:w-auto bg-yellow-400 text-blue-900 px-10 py-4 rounded-xl font-black text-lg hover:bg-yellow-300 transition-all uppercase italic shadow-lg">
                    Confirmar Reserva
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ DESTINOS_SUR, DESTINOS_NORTE }}>
  const select = document.getElementById('dest-select');
  const priceDisplay = document.getElementById('final-price');
  const dateInput = document.getElementById('travel-date');
  const form = document.getElementById('booking-form');

  // Establecer fecha mínima (hoy)
  const today = new Date().toISOString().split('T')[0];
  dateInput.min = today;
  dateInput.value = today;

  function loadDestinations() {
    const airport = document.querySelector('input[name="airport"]:checked').value;
    const destinos = airport === 'sur' ? DESTINOS_SUR : DESTINOS_NORTE;

    select.innerHTML = '<option value="" disabled selected>¿A dónde vas?</option>';
    destinos.forEach(dest => {
      const option = document.createElement('option');
      option.value = dest.price;
      option.textContent = dest.name;
      select.appendChild(option);
    });
    calculatePrice();
  }

  function calculatePrice() {
    const basePrice = parseInt(select.value) || 0;
    const vehicleInput = document.querySelector('input[name="vehicle"]:checked');
    const extra = parseInt(vehicleInput.getAttribute('data-extra')) || 0;

    if (basePrice === 0) {
      priceDisplay.textContent = "0,00";
    } else {
      const total = basePrice + extra;
      priceDisplay.textContent = total.toFixed(2).replace('.', ',');
    }
  }

  form.addEventListener('change', (e) => {
    if (e.target.name === 'airport') {
      loadDestinations();
    } else {
      calculatePrice();
    }
  });

  loadDestinations();

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    alert(`¡Reserva recibida! En breve contactaremos contigo para confirmar los detalles.`);
  });
</script>

<style>
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
</style>