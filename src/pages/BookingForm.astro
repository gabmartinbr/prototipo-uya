---
import Layout from "../layouts/Layout.astro";

// Definición de destinos y precios para tener el código limpio
const DESTINOS_SUR = [
  { id: "adeje", name: "Costa Adeje / Fañabé", price: 30 },
  { id: "cristianos", name: "Los Cristianos", price: 25 },
  { id: "americas", name: "Playa de las Américas", price: 28 },
  { id: "gigantes", name: "Los Gigantes / Pto. Santiago", price: 65 },
  { id: "golf", name: "Golf del Sur / Amarilla Golf", price: 20 },
  { id: "medano", name: "El Médano", price: 15 },
  { id: "callao", name: "Callao Salvaje / Playa Paraíso", price: 35 },
  { id: "alcala", name: "Alcalá", price: 45 },
  { id: "puerto", name: "Puerto de la Cruz", price: 110 },
  { id: "santacruz", name: "Santa Cruz de Tenerife", price: 85 },
];

const DESTINOS_NORTE = [
  { id: "santacruz", name: "Santa Cruz Centro", price: 20 },
  { id: "lalaguna", name: "La Laguna", price: 15 },
  { id: "puerto", name: "Puerto de la Cruz", price: 35 },
  { id: "orotava", name: "La Orotava", price: 40 },
  { id: "garachico", name: "Garachico", price: 75 },
  { id: "buenavista", name: "Buenavista del Norte", price: 95 },
  { id: "adeje_n", name: "Costa Adeje (Sur)", price: 105 },
  { id: "cristianos_n", name: "Los Cristianos (Sur)", price: 110 },
];
---

<Layout title="Reservar Traslado Oficial | TaxiAir">
  <section class="relative min-h-screen py-12 flex items-center justify-center bg-slate-900">
    <div class="absolute inset-0 z-0">
      <img
        src="https://plus.unsplash.com/premium_photo-1700566982560-31ed8b46991a?q=80&w=2000&auto=format&fit=crop"
        class="w-full h-full object-cover opacity-40"
        alt="Tenerife"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-blue-900/50 via-slate-900/80 to-slate-900"></div>
    </div>

    <div class="container mx-auto px-4 z-10">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-12 items-center">
        
        <div class="lg:col-span-5 text-white space-y-8">
          <div>
            <span class="bg-yellow-400 text-blue-900 px-4 py-1 rounded-full text-xs font-black uppercase tracking-widest inline-block mb-4">
              Taxi Oficial Tenerife
            </span>
            <h1 class="text-5xl md:text-6xl font-black leading-tight italic">
              TU VIAJE <span class="text-yellow-400 uppercase">PREMIUM</span> AL MEJOR PRECIO.
            </h1>
            <p class="text-lg text-slate-300 mt-6 leading-relaxed">
              Reserva tu traslado desde cualquiera de los dos aeropuertos. Sin esperas, sin colas y con precio cerrado.
            </p>
          </div>

          <div class="space-y-4">
            <div class="flex items-center gap-4 bg-white/5 p-4 rounded-2xl border border-white/10">
              <span class="text-3xl">📅</span>
              <div>
                <p class="font-bold">Reserva Flexible</p>
                <p class="text-sm text-slate-400">Cambia la fecha o cancela sin costes.</p>
              </div>
            </div>
            <div class="flex items-center gap-4 bg-white/5 p-4 rounded-2xl border border-white/10">
              <span class="text-3xl">🚼</span>
              <div>
                <p class="font-bold">Sillas Infantiles</p>
                <p class="text-sm text-slate-400">Incluidas bajo petición sin coste extra.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7">
          <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden">
            <div class="bg-blue-700 p-8 text-white flex justify-between items-end">
              <div class="space-y-1">
                <h2 class="text-3xl font-black italic uppercase leading-none">Reserva Online</h2>
              </div>
            </div>

            <form id="booking-form" class="p-8 space-y-6">
              
              <div class="grid md:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label class="text-[11px] font-black text-blue-600 uppercase tracking-widest ml-1">1. Aeropuerto Origen</label>
                  <div class="flex gap-2">
                    <label class="flex-1 cursor-pointer">
                      <input type="radio" name="airport" value="sur" checked class="sr-only peer" />
                      <div class="py-3 border-2 border-slate-100 rounded-xl bg-slate-50 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition-all text-center font-black text-slate-500 peer-checked:text-blue-700 uppercase text-xs">Sur (TFS)</div>
                    </label>
                    <label class="flex-1 cursor-pointer">
                      <input type="radio" name="airport" value="norte" class="sr-only peer" />
                      <div class="py-3 border-2 border-slate-100 rounded-xl bg-slate-50 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition-all text-center font-black text-slate-500 peer-checked:text-blue-700 uppercase text-xs">Norte (TFN)</div>
                    </label>
                  </div>
                </div>

                <div class="space-y-2">
                  <label for="travel-date" class="text-[11px] font-black text-blue-600 uppercase tracking-widest ml-1">2. Fecha de Viaje</label>
                  <input 
                    type="date" 
                    id="travel-date" 
                    required
                    class="w-full p-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:border-blue-600 outline-none font-bold text-slate-700"
                  />
                </div>
              </div>

              <div class="space-y-2">
                <label for="dest-select" class="text-[11px] font-black text-blue-600 uppercase tracking-widest ml-1">3. Destino del Traslado</label>
                <div class="relative">
                  <select 
                    id="dest-select" 
                    required
                    class="w-full p-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:border-blue-600 outline-none appearance-none font-bold text-slate-800 cursor-pointer"
                  >
                    </select>
                  <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-blue-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </div>
                </div>
              </div>

              <div class="space-y-2">
                <label class="text-[11px] font-black text-blue-600 uppercase tracking-widest ml-1">4. Selecciona Vehículo</label>
                <div class="grid grid-cols-3 gap-3">
                  {[
                    {id: 'standard', name: 'Taxi', pax: '1-4', icon: '🚕'},
                    {id: 'minivan', name: 'Van', pax: '5-8', icon: '🚐'},
                    {id: 'premium', name: 'Premium', pax: 'VIP', icon: '💼'}
                  ].map((v) => (
                    <label class="cursor-pointer">
                      <input type="radio" name="vehicle" value={v.id} checked={v.id === 'standard'} class="sr-only peer" />
                      <div class="p-3 border-2 border-slate-100 rounded-xl bg-slate-50 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition-all text-center">
                        <span class="block text-xl">{v.icon}</span>
                        <p class="font-black text-[10px] uppercase mt-1">{v.name}</p>
                        <p class="text-[9px] text-slate-400 font-bold">{v.pax} PAX</p>
                      </div>
                    </label>
                  ))}
                </div>
              </div>

              <div class="space-y-4 pt-4 border-t border-slate-100">
                <label class="text-[11px] font-black text-blue-600 uppercase tracking-widest ml-1">5. Tus Datos de Contacto</label>
                <div class="grid md:grid-cols-2 gap-4">
                  <div class="space-y-1">
                    <input 
                      type="text" 
                      placeholder="Nombre Completo" 
                      required
                      class="w-full p-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:border-blue-600 outline-none text-sm font-semibold"
                    />
                  </div>
                  <div class="space-y-1">
                    <input 
                      type="tel" 
                      placeholder="Teléfono" 
                      required
                      class="w-full p-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:border-blue-600 outline-none text-sm font-semibold"
                    />
                  </div>
                  <div class="md:col-span-2 space-y-1">
                    <input 
                      type="email" 
                      id="user-email"
                      placeholder="Email para recibir la reserva" 
                      required
                      class="w-full p-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:border-blue-600 outline-none text-sm font-semibold"
                    />
                  </div>
                </div>
              </div>

              <div class="bg-slate-900 rounded-[2rem] p-8 text-white shadow-2xl">
                <div class="flex flex-col md:flex-row justify-between items-center gap-6">
                  <div class="text-center md:text-left">
                    <p class="text-blue-400 text-[10px] font-black uppercase tracking-widest">Total a pagar en destino</p>
                    <div class="flex items-baseline justify-center md:justify-start gap-1">
                      <span id="final-price" class="text-5xl font-black text-yellow-400">0,00</span>
                      <span class="text-xl font-bold text-yellow-400">€</span>
                    </div>
                  </div>
                  <button 
                    type="submit" 
                    class="w-full md:w-auto bg-yellow-400 text-blue-900 px-12 py-5 rounded-2xl font-black text-xl hover:bg-yellow-300 transition-all active:scale-95 shadow-[0_10px_30px_rgba(234,179,8,0.3)] uppercase italic"
                  >
                    Confirmar Reserva
                  </button>
                </div>
              </div>

            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  input[type="date"]::-webkit-calendar-picker-indicator {
    cursor: pointer;
    padding: 5px;
    filter: invert(0.3);
  }
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0;
  }
</style>

<script define:vars={{ DESTINOS_SUR, DESTINOS_NORTE }}>
  const VEHICLE_EXTRA = { standard: 0, minivan: 20, premium: 35 };

  const select = document.getElementById('dest-select');
  const priceDisplay = document.getElementById('final-price');
  const dateInput = document.getElementById('travel-date');
  const form = document.getElementById('booking-form');
  const emailInput = document.getElementById('user-email');

  const today = new Date().toISOString().split('T')[0];
  dateInput.min = today;
  dateInput.value = today;

  function loadDestinations() {
    const airport = document.querySelector('input[name="airport"]:checked').value;
    const destinos = airport === 'sur' ? DESTINOS_SUR : DESTINOS_NORTE;

    select.innerHTML = '<option value="" disabled selected>Selecciona lugar de llegada...</option>';
    
    destinos.forEach(dest => {
      const option = document.createElement('option');
      option.value = dest.price;
      option.textContent = dest.name;
      select.appendChild(option);
    });
    
    calculatePrice();
  }

  function calculatePrice() {
    const basePrice = parseInt(select.value) || 0;
    const vehicle = document.querySelector('input[name="vehicle"]:checked').value;
    const extra = VEHICLE_EXTRA[vehicle];

    if (basePrice === 0) {
      priceDisplay.textContent = "0,00";
    } else {
      const total = basePrice + extra;
      priceDisplay.textContent = total.toFixed(2).replace('.', ',');
    }
  }

  form.addEventListener('change', (e) => {
    if (e.target.name === 'airport') {
      loadDestinations();
    } else {
      calculatePrice();
    }
  });

  loadDestinations();

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = emailInput.value;
    alert(`¡Reserva confirmada! Se ha enviado el ticket de reserva a: ${email}`);
  });
</script>