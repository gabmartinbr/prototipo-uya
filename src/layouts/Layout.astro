---
import "../styles/global.css";
interface Props {
  title: string;
}
const { title } = Astro.props;

// Obtenemos la ruta actual para el estado "active"
const pathname = new URL(Astro.url).pathname;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | Taxirife Tenerife</title>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:p-4 focus:bg-yellow-400 focus:text-blue-900 font-bold shadow-xl"
    >
      Saltar al contenido principal
    </a>

    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <nav class="container mx-auto px-4" aria-label="Navegación principal">
        <div class="flex justify-between items-center h-20">
          <a
            href="/"
            class="group flex items-center gap-1 focus:outline-none focus:ring-2 focus:ring-blue-600 rounded-lg p-1"
          >
            <span
              class="text-2xl font-black text-blue-700 tracking-tighter group-hover:text-blue-800 transition-colors"
              >TAXIRIFE</span
            >
            <span
              class="w-2 h-2 bg-yellow-400 rounded-full group-hover:animate-ping"
            ></span>
          </a>

          <ul
            class="hidden md:flex items-center gap-1 font-semibold text-slate-600"
          >
            <li>
              <a
                href="/"
                class={`px-4 py-2 rounded-lg transition-all hover:bg-slate-100 hover:text-blue-700 ${pathname === "/" ? "text-blue-700 bg-blue-50" : ""}`}
                >Inicio</a
              >
            </li>
            <li>
              <a
                href="/BookingForm"
                class={`px-4 py-2 rounded-lg transition-all hover:bg-slate-100 hover:text-blue-700 ${pathname.includes("BookingForm") ? "text-blue-700 bg-blue-50" : ""}`}
                >Reservar</a
              >
            </li>
            <li>
              <a
                href="/ManageBooking"
                class={`px-4 py-2 rounded-lg transition-all hover:bg-slate-100 hover:text-blue-700 ${pathname.includes("ManageBooking") ? "text-blue-700 bg-blue-50" : ""}`}
                >Mis Reservas</a
              >
            </li>
            <li>
              <a
                href="/ContactForm"
                class="ml-4 bg-blue-700 text-white px-6 py-2.5 rounded-full hover:bg-blue-800 hover:shadow-lg transition-all active:scale-95"
              >
                Contacto
              </a>
            </li>
          </ul>

          <button
            id="menu-button"
            class="md:hidden p-2 rounded-lg hover:bg-slate-100 focus:ring-2 focus:ring-blue-600 transition-colors"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Abrir menú de navegación"
          >
            <svg
              id="menu-icon"
              xmlns="http://www.w3.org/2000/svg"
              class="h-7 w-7 text-blue-900"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>

        <div
          id="mobile-menu"
          class="hidden md:hidden border-t border-slate-100 pb-6 transition-all duration-300"
        >
          <ul class="flex flex-col gap-2 pt-4">
            <li>
              <a
                href="/"
                class="block px-4 py-3 rounded-xl font-medium hover:bg-blue-50 hover:text-blue-700"
                >Inicio</a>
            </li>
            <li>
              <a
                href="/BookingForm"
                class="block px-4 py-3 rounded-xl font-medium hover:bg-blue-50 hover:text-blue-700"
                >Reservar</a>
            </li>
            <li>
              <a
                href="/ManageBooking"
                class="block px-4 py-3 rounded-xl font-medium hover:bg-blue-50 hover:text-blue-700"
                >Mis Reservas</a>
            </li>
            <li>
              <a
                href="/ContactForm"
                class="block px-4 py-3 mt-2 bg-yellow-400 text-blue-900 text-center rounded-xl font-bold"
                >Contacto</a>
            </li>
          </ul>
        </div>
      </nav>
    </header>

    <main id="main-content" class="grow">
      <slot />
    </main>

    <footer
      class="bg-slate-950 text-slate-400 pt-20 pb-10 border-t border-blue-900/30"
    >
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
          <div class="col-span-1 md:col-span-1">
            <div class="text-white text-3xl font-black mb-6 tracking-tighter">
              TAXIRIFE<span class="text-yellow-400">.</span>
            </div>
            <p class="text-sm leading-relaxed mb-6">
              Servicio oficial de traslados en la isla de Tenerife.
              Especialistas en puntualidad y confort desde el Aeropuerto Sur
              (TFS).
            </p>
            <div class="flex gap-4">
              <a
                href="#"
                aria-label="Facebook de Taxirife"
                class="w-10 h-10 rounded-full bg-slate-900 flex items-center justify-center hover:bg-blue-700 hover:text-white transition-colors"
              >
                <span aria-hidden="true">f</span>
              </a>
              <a
                href="#"
                aria-label="Instagram de Taxirife"
                class="w-10 h-10 rounded-full bg-slate-900 flex items-center justify-center hover:bg-blue-700 hover:text-white transition-colors"
              >
                <span aria-hidden="true">ig</span>
              </a>
            </div>
          </div>

          <div>
            <h3
              class="text-white font-bold mb-6 uppercase text-xs tracking-widest italic"
            >
              Servicios
            </h3>
            <ul class="space-y-4 text-sm font-medium">
              <li>
                <a
                  href="/BookingForm"
                  class="hover:text-yellow-400 transition-colors flex items-center gap-2"
                  ><span>→</span> Reservar Taxi</a>
              </li>
              <li>
                <a
                  href="/ManageBooking"
                  class="hover:text-yellow-400 transition-colors flex items-center gap-2"
                  ><span>→</span> Mis Reservas</a>
              </li>
              <li>
                <a
                  href="/ContactForm"
                  class="hover:text-yellow-400 transition-colors flex items-center gap-2"
                  ><span>→</span> Soporte 24h</a>
              </li>
              <li>
                <a
                  href="#"
                  class="hover:text-yellow-400 transition-colors flex items-center gap-2"
                  ><span>→</span> Tarifas 2026</a>
              </li>
            </ul>
          </div>

          <div>
            <h3
              class="text-white font-bold mb-6 uppercase text-xs tracking-widest italic"
            >
              Legal
            </h3>
            <ul class="space-y-4 text-sm">
              <li>
                <a href="#" class="hover:text-slate-200 transition-colors"
                  >Aviso Legal</a>
              </li>
              <li>
                <a href="#" class="hover:text-slate-200 transition-colors"
                  >Política de Privacidad</a>
              </li>
              <li>
                <a href="#" class="hover:text-slate-200 transition-colors"
                  >Uso de Cookies</a>
              </li>
              
            </ul>
          </div>

          <div class="bg-slate-900/50 p-6 rounded-2xl border border-slate-800">
            <h3
              class="text-white font-bold mb-4 uppercase text-xs tracking-widest italic"
            >
              Emergencias
            </h3>
            <p class="text-xs mb-4">
              ¿Tu vuelo se ha retrasado? Llámanos directamente:
            </p>
            <a
              href="tel:+34900000000"
              class="text-2xl font-black text-white hover:text-yellow-400 transition-colors block mb-2"
            >
              +34 922 00 00 00
            </a>
            <p
              class="text-[10px] text-slate-500 uppercase font-bold tracking-tighter"
            >
              Atención en Español, Inglés y Alemán
            </p>
          </div>
        </div>

        <div
          class="pt-10 border-t border-slate-900 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase font-bold tracking-widest"
        >
          <p>&copy; 2026 TAXIRIFE CANARIAS - LICENCIA VTC-TFS-001</p>
          <div class="flex gap-6">
            <span class="flex items-center gap-2 italic"
              ><span class="w-2 h-2 bg-green-500 rounded-full"></span> Sistema Operativo</span
            >
            <span class="flex items-center gap-2 italic"
              ><span class="w-2 h-2 bg-yellow-400 rounded-full"></span> Aeropuerto
              TFS</span
            >
          </div>
        </div>
      </div>
    </footer>

    <script>
      // Usamos una función para agrupar la lógica
      function initNavigation() {
        const menuButton = document.getElementById("menu-button");
        const mobileMenu = document.getElementById("mobile-menu");
        // Forzamos el tipo HTMLElement para que no dé error con .innerHTML
        const menuIcon = document.getElementById(
          "menu-icon",
        ) as HTMLElement | null;

        // Verificación de seguridad: si no existen, no hacemos nada
        if (!menuButton || !mobileMenu || !menuIcon) return;

        menuButton.addEventListener("click", () => {
          const expanded = menuButton.getAttribute("aria-expanded") === "true";
          const nextState = !expanded;

          // Actualizamos estado de accesibilidad
          menuButton.setAttribute("aria-expanded", nextState.toString());

          // Control de visibilidad
          mobileMenu.classList.toggle("hidden");

          // Cambio de icono (SVG Path)
          if (nextState) {
            // Icono de "X" (Cerrar)
            menuIcon.innerHTML =
              '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />';
          } else {
            // Icono de "Hamburguesa" (Abrir)
            menuIcon.innerHTML =
              '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />';
          }
        });
      }

      // Ejecución inicial
      initNavigation();

      // Si usas View Transitions de Astro, esto asegura que funcione al navegar
      document.addEventListener("astro:after-swap", initNavigation);
    </script>
  </body>
</html>
